{
  "name": "soc-web-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm -r --parallel --filter @soc/api --filter @soc/web dev",
    "dev:api": "pnpm --filter @soc/api dev",
    "dev:web": "pnpm --filter @soc/web dev",
    "db:migrate": "bash infra/scripts/db-migrate.sh",
    "db:seed": "bash infra/scripts/db-seed.sh",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0"
  }
}
